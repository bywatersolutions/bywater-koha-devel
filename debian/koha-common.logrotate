# Rotate log files for all Koha instances.

/var/log/koha/*/sip*.log {
    rotate 31
    daily
    missingok
    copytruncate
    compress
    delaycompress
    notifempty
}

/var/log/koha/*/*.log {
    rotate 5
    weekly
    size 500M
    missingok
    copytruncate
    compress
    delaycompress
    notifempty
    sharedscripts
    postrotate
        /etc/init.d/apache2 reload > /dev/null
    endscript
}
